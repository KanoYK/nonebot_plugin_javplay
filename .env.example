# NoneBot / JavPlay example configuration.
# Copy the relevant values into your NoneBot project's .env file.
# Do not put real cookies, API keys, or passwords in a public repository.

# Optional QQ notification target. 0 means disabled.
javplay_qq_user=0
javplay_qq_group=0

# Storage mode.
# aria2_cache: 115 offline -> Aria2 -> local cache. This is the stable default.
# 115_mount/clouddrive_mount: 115 offline selected video -> Jellyfin reads your mounted 115 path.
javplay_storage_mode="aria2_cache"

# 115 offline download.
# Leave javplay_115_cookie empty at first. The plugin will print a QR code and
# save QCcode.jpg in the plugin directory when login is required.
javplay_115_cookie=""
javplay_115_savepath="/PATH_IN_115_CLOUD/JAV"
# Required only when javplay_storage_mode="115_mount" or "clouddrive_mount".
# This must be the Jellyfin container path that points at javplay_115_savepath.
javplay_115_mount_jellyfin_path="/PATH_IN_JELLYFIN_CONTAINER/115-JAV"
# 115 mount mode tries to select only the real movie from a BT task.
javplay_115_min_video_size_mb=300
javplay_115_junk_keywords="广告,直播,最新地址,最新位址,社區,社区,收藏不迷路,防迷路,防走丢,网址,地址,489155.com,.html,.txt"
javplay_115_require_wanted_selection=true

# JavDB access.
# If your FlareSolverr server needs an upstream proxy, set javplay_flaresolverr_proxy.
javplay_proxy_http=""
javplay_flaresolverr_url="http://YOUR_FLARESOLVERR_HOST:8191"
javplay_flaresolverr_proxy=""

# Aria2 RPC. Required only when javplay_storage_mode="aria2_cache".
javplay_aria2_rpc="http://YOUR_ARIA2_HOST:6800/jsonrpc"
javplay_aria2_secret="YOUR_ARIA2_RPC_SECRET"
javplay_aria2_dir="/PATH_IN_ARIA2_CONTAINER/JAV"
javplay_aria2_poll_interval_seconds=30
javplay_aria2_poll_timeout_hours=24
javplay_local_complete_min_size_mb=50

# Jellyfin API.
javplay_jellyfin_url="http://YOUR_JELLYFIN_HOST:8096"
javplay_jellyfin_api_key="YOUR_JELLYFIN_API_KEY"

# Optional shared token for /webhook/jellyfin and /webhook/aria2.
# Keep empty only on a trusted LAN.
javplay_webhook_token=""
javplay_jellyfin_message_timeout_ms=30000
javplay_jellyfin_item_refresh_wait_seconds=180
javplay_jellyfin_item_refresh_interval_seconds=5

# Media path mapping.
# These three paths must point to the same underlying media directory from
# different process/container viewpoints.
javplay_db_path="/PATH_ON_BOT_HOST/JAV"
javplay_cache_host_path="/PATH_ON_BOT_HOST/JAV"
javplay_jellyfin_media_path="/PATH_IN_JELLYFIN_CONTAINER/JAV"

# URL that Jellyfin can reach to play the waiting video.
# This is usually your NoneBot host and port.
javplay_strm_url="http://YOUR_NONEBOT_HOST:14514/wait.mp4"

# JavDB crawl settings.
# Daily latest-page crawl runs at 05:00 Asia/Shanghai by default.
javplay_crawl_pages_daily=5
javplay_daily_crawl_hour=5
javplay_daily_crawl_minute=0
javplay_scheduler_timezone="Asia/Shanghai"
javplay_crawl_start_page=1
javplay_crawl_max_page=2000
javplay_full_scan_state_file="page.json"
# Internal batch size for 完全扫描jav. The command keeps running batch by batch
# until JavDB has no more items or javplay_crawl_max_page is reached.
javplay_full_scan_pages_per_run=50
javplay_manual_crawl_pages=1
javplay_manual_crawl_max_pages=3

# Local cache cleanup. This only cleans local downloaded files, not 115 cloud files.
javplay_cleanup_enabled=true
javplay_cleanup_keep_hours=24
javplay_cleanup_interval_minutes=60

